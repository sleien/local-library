# Copy this file to .env and adjust the values before running docker compose.

# Required. Used to sign session and auth tokens. Generate a long random string,
# for example: openssl rand -hex 32
SECRET_KEY=

# Public URL where the app is reachable. Needed for OIDC redirects and links.
PUBLIC_URL=http://localhost:8000

# Host port to expose the app on.
PORT=8000

# Set to true when serving over HTTPS so auth cookies are marked Secure.
COOKIE_SECURE=false

# When false, new accounts can only be created via an invite link.
ALLOW_REGISTRATION=true

# Database credentials (used by both the db service and the app).
POSTGRES_USER=bibliothek
POSTGRES_PASSWORD=bibliothek
POSTGRES_DB=bibliothek

# --- Authentik / OpenID Connect (optional single sign-on) ---
# Must be true for the "Continue with Authentik" button to appear.
OIDC_ENABLED=false
# From your Authentik provider. Either the issuer URL or the full
# .well-known/openid-configuration URL works, e.g.
#   https://authentik.example.com/application/o/<slug>/
# Also add this exact redirect URI to the provider:
#   <PUBLIC_URL>/api/auth/oidc/callback
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISPLAY_NAME=Authentik

# Container image to use when not building locally.
# IMAGE=ghcr.io/sleien/local-library:latest
